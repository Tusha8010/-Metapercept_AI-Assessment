import chromadb
from sentence_transformers import SentenceTransformer
import string

documents = [
    "Artificial Intelligence enables machines to perform tasks that require human intelligence.",
    "Machine Learning is a subset of Artificial Intelligence.",
    "Deep Learning uses neural networks with multiple layers.",
    "ChromaDB is a vector database used to store embeddings.",
    "Python is widely used for Artificial Intelligence and Machine Learning."
]

def preprocess(text):
    text = text.lower()
    text = text.translate(str.maketrans('', '', string.punctuation))
    return text

processed_docs = [preprocess(doc) for doc in documents]

model = SentenceTransformer("all-MiniLM-L6-v2")

embeddings = model.encode(processed_docs).tolist()

client = chromadb.Client()

collection = client.create_collection("mini_rag")

collection.add(
    ids=[str(i) for i in range(len(processed_docs))],
    documents=processed_docs,
    embeddings=embeddings
)

query = input("Enter your question: ")

query = preprocess(query)

query_embedding = model.encode([query]).tolist()

result = collection.query(
    query_embeddings=query_embedding,
    n_results=1
)

print("\nMost Relevant Document:")
print(result["documents"][0][0])
