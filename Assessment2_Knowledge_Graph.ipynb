from rdflib import Graph, Namespace, RDF
from sentence_transformers import SentenceTransformer
import chromadb
import string

g = Graph()
EX = Namespace("http://example.org/")

g.add((EX.Alice, RDF.type, EX.Person))
g.add((EX.Alice, EX.knows, EX.Bob))
g.add((EX.Bob, EX.worksAt, EX.AcmeCorp))
g.add((EX.Bob, EX.livesIn, EX.Pune))
g.add((EX.Charlie, EX.knows, EX.Alice))

sentences = []

for s, p, o in g:
    subject = s.split("/")[-1]
    predicate = p.split("/")[-1]
    obj = o.split("/")[-1]
    sentences.append(f"{subject} {predicate} {obj}")

def preprocess(text):
    text = text.lower()
    text = text.translate(str.maketrans('', '', string.punctuation))
    return text

processed_sentences = [preprocess(sentence) for sentence in sentences]

model = SentenceTransformer("all-MiniLM-L6-v2")

embeddings = model.encode(processed_sentences).tolist()

client = chromadb.Client()

collection = client.create_collection("knowledge_graph")

collection.add(
    ids=[str(i) for i in range(len(processed_sentences))],
    documents=processed_sentences,
    embeddings=embeddings
)

query = input("Enter your question: ")

query = preprocess(query)

query_embedding = model.encode([query]).tolist()

result = collection.query(
    query_embeddings=query_embedding,
    n_results=1
)

print("\nMost Relevant Answer:")
print(result["documents"][0][0])
